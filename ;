`timescale 1ns/1ps

module shic_top (
  input logic clk,
  input logic rst_n,
  output logic [31:0] current_pc
);
  logic [31:0] next_pc;

  shic_pc pc_reg (
    .clk(clk),
    .rst_n(rst_n),
    .next_pc(next_pc),
    .pc(current_pc)
    );

    adder_32bit pc_increament (
      .A(current_pc),
      .B(32'd4),
      .Cin(1'b0),
      .S(next_pc),
      .Cout()
      );
endmodule
